[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    true-color = always
    dark = true
    syntax-theme = gruvbox-dark
    plus-style = "#ebdbb2" "#4b5632"
    plus-emph-style = "#ebdbb2" "#98971a"
    minus-style = "#ebdbb2" "#53302a"
    minus-emph-style = "#ebdbb2" "#cc241d"
    line-numbers = true
    line-numbers-plus-style = "#98971a"
    line-numbers-minus-style = "#cc241d"
